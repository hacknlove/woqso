#!/bin/bash

set -euo pipefail

fail_with_error() {
  local cause="$1"

  trap - ERR
  set +e

  if [ -n "${repo_root:-}" ] && [ -d "$repo_root" ]; then
    git -C "$repo_root" add -A -- . ':(exclude).dwp/logs' 2>/dev/null || true
  fi

  aynig set-state \
    --dwp-state error \
    --subject "revisit-plan: error" \
    --keep-trailers \
    --prompt "Command failed while revisiting the plan.

Cause:
$cause"

  exit 1
}

on_error() {
  local exit_code=$?
  local line_number="$1"

  fail_with_error "${BASH_COMMAND} (line ${line_number}, exit ${exit_code})"
}

trap 'on_error "$LINENO"' ERR

trim() {
  printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

body="$(trim "${AYNIG_BODY:-}")"
ticket_input="$(trim "${AYNIG_TRAILER_DWP_TICKET:-}")"
planner_session_id="$(trim "${AYNIG_TRAILER_DWP_PLANNER_SESSION_ID:-}")"
current_plan_version="$(trim "${AYNIG_TRAILER_DWP_PLAN_VERSION:-}")"
implementer_session_id="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTER_SESSION_ID:-}")"
current_implementation_version="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTATION_VERSION:-}")"

if [ -z "$ticket_input" ]; then
  fail_with_error "Missing dwp-ticket trailer"
fi

if [ -z "$body" ]; then
  fail_with_error "Missing implementer questions or plan feedback in commit body"
fi

if [ -z "$planner_session_id" ]; then
  fail_with_error "Missing dwp-planner-session-id trailer"
fi

if [ -z "$current_plan_version" ]; then
  fail_with_error "Missing dwp-plan-version trailer; cannot revisit plan"
elif [[ "$current_plan_version" =~ ^[0-9]+$ ]]; then
  next_plan_version=$((current_plan_version + 1))
else
  fail_with_error "Invalid dwp-plan-version trailer: $current_plan_version"
fi

if [ -z "$implementer_session_id" ]; then
  fail_with_error "Missing dwp-implementer-session-id trailer"
fi

if [ -z "$current_implementation_version" ]; then
  fail_with_error "Missing dwp-implementation-version trailer"
fi

if ! [[ "$current_implementation_version" =~ ^[0-9]+$ ]]; then
  fail_with_error "Invalid dwp-implementation-version trailer: $current_implementation_version"
fi

repo_root="$(git rev-parse --show-toplevel)"

case "$ticket_input" in
  /*) ticket_path="$ticket_input" ;;
  *) ticket_path="$repo_root/$ticket_input" ;;
esac

if [ ! -f "$ticket_path" ]; then
  fail_with_error "Ticket not found: $ticket_path"
fi

ticket_file="$(basename "$ticket_path")"
ticket_name="${ticket_file%.md}"
relative_ticket_path="${ticket_path#$repo_root/}"
commit_hash="$(trim "${AYNIG_COMMIT_HASH:-}")"

if [ -z "$commit_hash" ]; then
  fail_with_error "Missing AYNIG_COMMIT_HASH"
fi

logs_dir="$repo_root/.dwp/logs"
output_path="$logs_dir/dwp-output-${commit_hash}.md"
relative_output_path="${output_path#$repo_root/}"
run_title="${commit_hash}-revisit-plan"

mkdir -p "$logs_dir"
: > "$output_path"

prompt=$(cat <<EOF
You are revisiting the ticket plan based on questions or friction discovered during implementation.

Your job:
1. Review the current ticket plan, the implementer's feedback, and the current repository state.
2. Decide whether the planner can resolve the issue by updating or clarifying the plan.
3. If yes, update the ticket plan so implementation can continue.
4. In all cases, write a short handoff for the implementer in the output file.

Repository context:
- This repository is for woqso.com, a GUI that visualizes the state of repositories that use DWP/git.
- This is not the repository for the DWP protocol or AYNIG implementation itself.
- Treat SPEC.md as the primary product source of truth, then IMPLEMENTATION_PLAN.md, then the ticket.
- Keep these layers clearly separated in your reasoning and writing:
  - DWP/GC protocol facts
  - Git inspection facts
  - UI diagnostics and product heuristics
- This app is read-only in v1 except for explicit remote fetch.

Decision rule:
- Choose iterate-implementation when you can resolve the implementation blocker by clarifying or updating the plan from existing repo context.
- Choose call-human only when the implementer's questions reveal a real blocker that requires human clarification, prioritization, or a product decision that cannot be inferred from the repo context.
- Do not use call-human for normal implementation uncertainty or fixable plan gaps; update the plan when you can responsibly unblock the implementer.

Planning requirements:
- Inspect the current repository state, including any partial implementation work, only to understand the implementation issue.
- Do not review or revert implementation code; focus on clarifying or adjusting the plan.
- Edit the ticket file in place when you can improve the plan.
- Update the existing Plan section to address the implementation questions when appropriate.
- Keep the plan actionable and aligned with the ticket deliverable.
- Do not modify unrelated ticket content.

Required output file contract:
- The first line must be exactly one of:
  - Decision: iterate-implementation
  - Decision: call-human
- After the decision line, write the message for the next actor.
- There are no additional syntax requirements for the rest of the file.
- The implementer will resume work from an existing implementation session, so include any clarification, plan change, caveat, or constraint they need in order to continue safely.

Files:
- Target ticket: $relative_ticket_path
- Output file: $relative_output_path

Implementer feedback for the planner:
$body
EOF
)

opencode run \
  -m openai/gpt-5.4 \
  --dir "$repo_root" \
  --session "$planner_session_id" \
  --title "$run_title" \
  -f "$repo_root/SPEC.md" \
  -f "$repo_root/IMPLEMENTATION_PLAN.md" \
  -f "$ticket_path" \
  -f "$output_path" \
  "$prompt"

output_body="$(<"$output_path")"

if [ -z "$output_body" ]; then
  fail_with_error "Output file was empty at ${relative_output_path}"
fi

IFS= read -r decision_line < "$output_path"
decision_line="$(trim "$decision_line")"

case "$decision_line" in
  "Decision: iterate-implementation")
    next_state="iterate-implementation"
    next_subject="revisit-plan: update ${ticket_name} plan"
    ;;
  "Decision: call-human")
    next_state="call-human"
    next_subject="revisit-plan: needs human input for ${ticket_name}"
    ;;
  *)
    fail_with_error "Invalid output decision in ${relative_output_path}: $decision_line"
    ;;
esac

git -C "$repo_root" add -A -- . ':(exclude).dwp/logs'
aynig set-state \
  --dwp-state "$next_state" \
  --subject "$next_subject" \
  --trailer "dwp-ticket: ${relative_ticket_path}" \
  --trailer "dwp-plan-version: ${next_plan_version}" \
  --trailer "dwp-planner-session-id: ${planner_session_id}" \
  --trailer "dwp-implementation-version: ${current_implementation_version}" \
  --trailer "dwp-implementer-session-id: ${implementer_session_id}" \
  --prompt "$output_body"
