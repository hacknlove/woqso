#!/bin/bash

set -euo pipefail

fail_with_error() {
  local cause="$1"

  trap - ERR
  set +e

  if [ -n "${ticket_path:-}" ] && [ -f "${ticket_path}" ]; then
    git add "$ticket_path" 2>/dev/null || true
  fi

  aynig set-state \
    --dwp-state error \
    --subject "iterate-plan: error" \
    --keep-trailers \
    --prompt "Command failed while revising the plan.

Cause:
$cause"

  exit 1
}

on_error() {
  local exit_code=$?
  local line_number="$1"

  fail_with_error "${BASH_COMMAND} (line ${line_number}, exit ${exit_code})"
}

trap 'on_error "$LINENO"' ERR

trim() {
  printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

resolve_ticket_path() {
  printf '%s' "${AYNIG_TRAILER_DWP_TICKET:-}"
}

body="$(trim "${AYNIG_BODY:-}")"
ticket_input="$(trim "$(resolve_ticket_path)")"

if [ -z "$ticket_input" ]; then
  fail_with_error "Missing dwp-ticket trailer"
fi

if [ -z "$body" ]; then
  fail_with_error "Missing reviewer feedback in commit body"
fi

repo_root="$(git rev-parse --show-toplevel)"

case "$ticket_input" in
  /*) ticket_path="$ticket_input" ;;
  *) ticket_path="$repo_root/$ticket_input" ;;
esac

if [ ! -f "$ticket_path" ]; then
  fail_with_error "Ticket not found: $ticket_path"
fi

ticket_file="$(basename "$ticket_path")"
ticket_name="${ticket_file%.md}"
relative_ticket_path="${ticket_path#$repo_root/}"
planner_session_id="$(trim "${AYNIG_TRAILER_DWP_PLANNER_SESSION_ID:-}")"
current_plan_version="$(trim "${AYNIG_TRAILER_DWP_PLAN_VERSION:-}")"
commit_hash="$(trim "${AYNIG_COMMIT_HASH:-}")"

if [ -z "$commit_hash" ]; then
  fail_with_error "Missing AYNIG_COMMIT_HASH"
fi

if [ -z "$planner_session_id" ]; then
  fail_with_error "Missing dwp-planner-session-id trailer; use plan for the initial version"
fi

if [ -z "$current_plan_version" ]; then
  fail_with_error "Missing dwp-plan-version trailer; cannot iterate plan"
elif [[ "$current_plan_version" =~ ^[0-9]+$ ]]; then
  next_plan_version=$((current_plan_version + 1))
else
  fail_with_error "Invalid dwp-plan-version trailer: $current_plan_version"
fi

logs_dir="$repo_root/.dwp/logs"
output_path="$logs_dir/dwp-output-${commit_hash}.md"
relative_output_path="${output_path#$repo_root/}"
run_title="${commit_hash}-iterate-plan"

mkdir -p "$logs_dir"
: > "$output_path"

prompt=$(cat <<EOF
You are revising the ticket plan based on reviewer feedback.

Your job:
1. Review the feedback.
2. Update your plan to address the feedback.
3. Communicate any important caveats for the next actor.

Decision rule:
- Choose `review-plan` when you can revise the plan without needing human intervention.
- Choose `call-human` only when the reviewer feedback reveals a real blocker that requires human clarification, prioritization, or a product decision that cannot be inferred from the existing context.
- Do not use `call-human` for normal review feedback, fixable gaps, or disagreements that can be resolved by updating the plan.

Editing requirements:
- Edit the ticket file in place.
- Update the existing `## Plan` section to address the reviewer feedback when appropriate.
- Keep the plan actionable and aligned with the ticket deliverable.
- Do not modify unrelated ticket content.

Required output file contract:
- The first line must be exactly one of:
  - `Decision: review-plan`
  - `Decision: call-human`
- After the decision line, write the message for the next actor.
- There are no additional syntax requirements for the rest of the file.
- The next reviewer will not have your prior session context, so include any information that helps them get up to speed, understand your reasoning, and continue the workflow.
- If you do not apply some reviewer feedback, explain better the plan so the next reviewer don't ask for the same change again.

Files:
- Target ticket: $relative_ticket_path
- Output file: $relative_output_path

Reviewer feedback for your plan:
$body
EOF
)

opencode run \
  -m openai/gpt-5.4 \
  --dir "$repo_root" \
  --session "$planner_session_id" \
  --title "$run_title" \
  -f "$ticket_path" \
  -f "$output_path" \
  "$prompt"

output_body="$(<"$output_path")"

if [ -z "$output_body" ]; then
  fail_with_error "Output file was empty at ${relative_output_path}"
fi

IFS= read -r decision_line < "$output_path"
decision_line="$(trim "$decision_line")"

case "$decision_line" in
  "Decision: review-plan")
    next_state="review-plan"
    next_subject="iterate-plan: revise ${ticket_name} plan"
    ;;
  "Decision: call-human")
    next_state="call-human"
    next_subject="iterate-plan: needs human input for ${ticket_name}"
    ;;
  *)
    fail_with_error "Invalid output decision in ${relative_output_path}: $decision_line"
    ;;
esac

git add "$ticket_path"
aynig set-state \
  --dwp-state "$next_state" \
  --subject "$next_subject" \
  --keep-trailers \
  --trailer "dwp-ticket: ${relative_ticket_path}" \
  --trailer "dwp-plan-version: ${next_plan_version}" \
  --trailer "dwp-planner-session-id: ${planner_session_id}" \
  --prompt "$output_body"
