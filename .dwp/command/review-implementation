#!/bin/bash

set -euo pipefail

fail_with_error() {
  local cause="$1"

  trap - ERR
  set +e

  aynig set-state \
    --dwp-state error \
    --subject "review-implementation: error" \
    --keep-trailers \
    --prompt "Command failed while reviewing the implementation.

Cause:
$cause"

  exit 1
}

on_error() {
  local exit_code=$?
  local line_number="$1"

  fail_with_error "${BASH_COMMAND} (line ${line_number}, exit ${exit_code})"
}

trap 'on_error "$LINENO"' ERR

trim() {
  printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

body="$(trim "${AYNIG_BODY:-}")"
ticket_input="$(trim "${AYNIG_TRAILER_DWP_TICKET:-}")"
planner_session_id="$(trim "${AYNIG_TRAILER_DWP_PLANNER_SESSION_ID:-}")"
current_plan_version="$(trim "${AYNIG_TRAILER_DWP_PLAN_VERSION:-}")"
implementer_session_id="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTER_SESSION_ID:-}")"
current_implementation_version="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTATION_VERSION:-}")"

if [ -z "$ticket_input" ]; then
  fail_with_error "Missing dwp-ticket trailer"
fi

if [ -z "$planner_session_id" ]; then
  fail_with_error "Missing dwp-planner-session-id trailer"
fi

if [ -z "$current_plan_version" ]; then
  fail_with_error "Missing dwp-plan-version trailer"
fi

if ! [[ "$current_plan_version" =~ ^[0-9]+$ ]]; then
  fail_with_error "Invalid dwp-plan-version trailer: $current_plan_version"
fi

if [ -z "$implementer_session_id" ]; then
  fail_with_error "Missing dwp-implementer-session-id trailer"
fi

if [ -z "$current_implementation_version" ]; then
  fail_with_error "Missing dwp-implementation-version trailer"
fi

if ! [[ "$current_implementation_version" =~ ^[0-9]+$ ]]; then
  fail_with_error "Invalid dwp-implementation-version trailer: $current_implementation_version"
fi

if [ -z "$body" ]; then
  fail_with_error "Missing latest implementation notes for reviewer in commit body"
fi

repo_root="$(git rev-parse --show-toplevel)"

case "$ticket_input" in
  /*) ticket_path="$ticket_input" ;;
  *) ticket_path="$repo_root/$ticket_input" ;;
esac

if [ ! -f "$ticket_path" ]; then
  fail_with_error "Ticket not found: $ticket_path"
fi

ticket_file="$(basename "$ticket_path")"
ticket_name="${ticket_file%.md}"
relative_ticket_path="${ticket_path#$repo_root/}"
logs_dir="$repo_root/.dwp/logs"
commit_hash="$(trim "${AYNIG_COMMIT_HASH:-}")"

if [ -z "$commit_hash" ]; then
  fail_with_error "Missing AYNIG_COMMIT_HASH"
fi

output_path="$logs_dir/dwp-output-${commit_hash}.md"
relative_output_path="${output_path#$repo_root/}"
run_title="${commit_hash}-review-implementation"

mkdir -p "$logs_dir"
: > "$output_path"

prompt=$(cat <<EOF
You are reviewing the current ticket implementation for one ticket in the woqso.com product repo.

Your job:
1. Review the ticket, its approved plan, and the implementation as it exists now in the repository.
2. Use the latest implementer notes as review context.
3. Decide whether the implementation should move to QA planning, be revised again, or be escalated to a human.
4. Write a short handoff for the next actor in the output file.

Repository context:
- This repository is for woqso.com, a GUI that visualizes the state of repositories that use DWP/git.
- This is not the repository for the DWP protocol or AYNIG implementation itself.
- Treat SPEC.md as the primary product source of truth, then IMPLEMENTATION_PLAN.md, then the ticket.
- Keep these layers clearly separated in your reasoning and writing:
  - DWP/GC protocol facts
  - Git inspection facts
  - UI diagnostics and product heuristics
- This review must be fresh each time; do not rely on previous reviewer sessions.

Decision rule:
- Choose qa-plan when the current implementation is good enough to hand off into QA planning.
- Choose iterate-implementation when the implementation can be improved by another implementation pass without needing a human decision.
- Choose call-human only when progress is genuinely blocked on human clarification, prioritization, or a product decision that cannot be inferred from the repo context.
- Do not use call-human for normal review feedback, minor ambiguities, or fixable implementation gaps; use iterate-implementation for those.
- When dwp-implementation-version is 3 or higher, tolerate minor issues and request another iteration only for substantive problems.

What to review:
- Product correctness relative to SPEC.md, IMPLEMENTATION_PLAN.md, and the ticket plan.
- Whether the implementation stays within the ticket's intended scope.
- Whether DWP/GC protocol facts, Git inspection facts, and UI diagnostics are kept distinct.
- Whether the code changes are coherent, verification is credible, and obvious regressions or missing pieces remain.
- Whether any remaining assumptions, dependencies, or scope problems materially affect readiness.
- Whether the current implementation is ready for QA planning.

Required output file contract:
- Write the review to $relative_output_path.
- The first line of the file must be exactly one of:
  - Decision: qa-plan
  - Decision: iterate-implementation
  - Decision: call-human
- After the decision line, write the message for the next actor.
- There are no additional syntax requirements for the rest of the file.
- Do not include system logs, raw tool output, or irrelevant analysis.

What to write in the output file:
- If the decision is qa-plan, explain briefly why the implementation is ready for QA planning and note any important caveats the QA planner should keep in mind.
- If the decision is iterate-implementation, explain clearly what must change before the implementation is ready. Be specific and actionable.
- If the decision is call-human, explain exactly what human input is required, why it is necessary, and why the issue cannot be resolved through another implementation iteration.

Files:
- Target ticket: $relative_ticket_path
- Output file: $relative_output_path

Implementer Notes:
$body
EOF
)

opencode run \
  -m openai/gpt-5.4 \
  --dir "$repo_root" \
  --title "$run_title" \
  -f "$repo_root/SPEC.md" \
  -f "$repo_root/IMPLEMENTATION_PLAN.md" \
  -f "$ticket_path" \
  -f "$output_path" \
  "$prompt"

output_body="$(<"$output_path")"

if [ -z "$output_body" ]; then
  fail_with_error "Output file was empty: $relative_output_path"
fi

IFS= read -r decision_line < "$output_path"
decision_line="$(trim "$decision_line")"

case "$decision_line" in
  "Decision: qa-plan")
    next_state="qa-plan"
    next_subject="review-implementation: approve ${ticket_name} for qa planning"
    ;;
  "Decision: iterate-implementation")
    next_state="iterate-implementation"
    next_subject="review-implementation: request ${ticket_name} implementation changes"
    ;;
  "Decision: call-human")
    next_state="call-human"
    next_subject="review-implementation: needs human input for ${ticket_name}"
    ;;
  *)
    fail_with_error "Invalid review decision in $relative_output_path: $decision_line"
    ;;
esac

aynig set-state \
  --dwp-state "$next_state" \
  --subject "$next_subject" \
  --trailer "dwp-ticket: ${relative_ticket_path}" \
  --trailer "dwp-plan-version: ${current_plan_version}" \
  --trailer "dwp-planner-session-id: ${planner_session_id}" \
  --trailer "dwp-implementation-version: ${current_implementation_version}" \
  --trailer "dwp-implementer-session-id: ${implementer_session_id}" \
  --prompt "$output_body"
