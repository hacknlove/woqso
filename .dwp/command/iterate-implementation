#!/bin/bash

set -euo pipefail

fail_with_error() {
  local cause="$1"

  trap - ERR
  set +e

  if [ -n "${repo_root:-}" ] && [ -d "$repo_root" ]; then
    git -C "$repo_root" add -A -- . ':(exclude).dwp/logs' 2>/dev/null || true
  fi

  aynig set-state \
    --dwp-state error \
    --subject "iterate-implementation: error" \
    --keep-trailers \
    --prompt "Command failed while revising the implementation.

Cause:
$cause"

  exit 1
}

on_error() {
  local exit_code=$?
  local line_number="$1"

  fail_with_error "${BASH_COMMAND} (line ${line_number}, exit ${exit_code})"
}

trap 'on_error "$LINENO"' ERR

trim() {
  printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

body="$(trim "${AYNIG_BODY:-}")"
ticket_input="$(trim "${AYNIG_TRAILER_DWP_TICKET:-}")"
planner_session_id="$(trim "${AYNIG_TRAILER_DWP_PLANNER_SESSION_ID:-}")"
current_plan_version="$(trim "${AYNIG_TRAILER_DWP_PLAN_VERSION:-}")"
implementer_session_id="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTER_SESSION_ID:-}")"
current_implementation_version="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTATION_VERSION:-}")"

if [ -z "$ticket_input" ]; then
  fail_with_error "Missing dwp-ticket trailer"
fi

if [ -z "$body" ]; then
  fail_with_error "Missing reviewer feedback in commit body"
fi

if [ -z "$planner_session_id" ]; then
  fail_with_error "Missing dwp-planner-session-id trailer"
fi

if [ -z "$current_plan_version" ]; then
  fail_with_error "Missing dwp-plan-version trailer"
fi

if ! [[ "$current_plan_version" =~ ^[0-9]+$ ]]; then
  fail_with_error "Invalid dwp-plan-version trailer: $current_plan_version"
fi

if [ -z "$implementer_session_id" ]; then
  fail_with_error "Missing dwp-implementer-session-id trailer; use implement for the initial version"
fi

if [ -z "$current_implementation_version" ]; then
  fail_with_error "Missing dwp-implementation-version trailer; cannot iterate implementation"
elif [[ "$current_implementation_version" =~ ^[0-9]+$ ]]; then
  next_implementation_version=$((current_implementation_version + 1))
else
  fail_with_error "Invalid dwp-implementation-version trailer: $current_implementation_version"
fi

repo_root="$(git rev-parse --show-toplevel)"

case "$ticket_input" in
  /*) ticket_path="$ticket_input" ;;
  *) ticket_path="$repo_root/$ticket_input" ;;
esac

if [ ! -f "$ticket_path" ]; then
  fail_with_error "Ticket not found: $ticket_path"
fi

ticket_file="$(basename "$ticket_path")"
ticket_name="${ticket_file%.md}"
relative_ticket_path="${ticket_path#$repo_root/}"
commit_hash="$(trim "${AYNIG_COMMIT_HASH:-}")"

if [ -z "$commit_hash" ]; then
  fail_with_error "Missing AYNIG_COMMIT_HASH"
fi

logs_dir="$repo_root/.dwp/logs"
output_path="$logs_dir/dwp-output-${commit_hash}.md"
relative_output_path="${output_path#$repo_root/}"
run_title="${commit_hash}-iterate-implementation"

mkdir -p "$logs_dir"
: > "$output_path"

prompt=$(cat <<EOF
You are revising the ticket implementation based on reviewer feedback.

Your job:
1. Review the feedback.
2. Update the implementation to address the feedback.
3. Re-run focused verification appropriate to your changes.
4. Communicate any important caveats for the next actor.

Decision rule:
- Choose review-implementation when you can revise the implementation without needing human intervention.
- Choose revisit-plan when implementation work reveals a real plan ambiguity, contradiction, or missing guidance that should be resolved by the planner before implementation continues.
- Choose call-human only when the reviewer feedback reveals a real blocker that requires human clarification, prioritization, or a product decision that cannot be inferred from the existing context.
- Do not use call-human for normal review feedback, fixable gaps, or disagreements that can be resolved by updating the implementation.
- Prefer revisit-plan over call-human when the planner can likely unblock the issue from existing repo context.

Implementation requirements:
- Update the repository in place to address the reviewer feedback when appropriate.
- Stay within the ticket scope and approved plan unless the feedback reveals a necessary correction.
- Keep protocol facts, Git inspection facts, and UI diagnostics clearly separated.
- Do not modify unrelated files.

Required output file contract:
- The first line must be exactly one of:
  - Decision: review-implementation
  - Decision: revisit-plan
  - Decision: call-human
- After the decision line, write the message for the next actor.
- There are no additional syntax requirements for the rest of the file.
- The next reviewer will not have your prior session context, so include any information that helps them get up to speed, understand your reasoning, and continue the workflow.
- If the decision is revisit-plan, explain what you discovered during implementation, what question or plan change is needed, and what partial implementation work already exists.
- If you do not apply some reviewer feedback, explain why clearly so the next reviewer does not ask for the same change again.

Files:
- Target ticket: $relative_ticket_path
- Output file: $relative_output_path

Reviewer feedback for your implementation:
$body
EOF
)

opencode run \
  -m openai/gpt-5.4 \
  --dir "$repo_root" \
  --session "$implementer_session_id" \
  --title "$run_title" \
  -f "$repo_root/SPEC.md" \
  -f "$repo_root/IMPLEMENTATION_PLAN.md" \
  -f "$ticket_path" \
  -f "$output_path" \
  "$prompt"

output_body="$(<"$output_path")"

if [ -z "$output_body" ]; then
  fail_with_error "Output file was empty at ${relative_output_path}"
fi

IFS= read -r decision_line < "$output_path"
decision_line="$(trim "$decision_line")"

case "$decision_line" in
  "Decision: review-implementation")
    next_state="review-implementation"
    next_subject="iterate-implementation: revise ${ticket_name} implementation"
    ;;
  "Decision: revisit-plan")
    next_state="revisit-plan"
    next_subject="iterate-implementation: revisit ${ticket_name} plan"
    ;;
  "Decision: call-human")
    next_state="call-human"
    next_subject="iterate-implementation: needs human input for ${ticket_name}"
    ;;
  *)
    fail_with_error "Invalid output decision in ${relative_output_path}: $decision_line"
    ;;
esac

git -C "$repo_root" add -A -- . ':(exclude).dwp/logs'
aynig set-state \
  --dwp-state "$next_state" \
  --subject "$next_subject" \
  --trailer "dwp-ticket: ${relative_ticket_path}" \
  --trailer "dwp-plan-version: ${current_plan_version}" \
  --trailer "dwp-planner-session-id: ${planner_session_id}" \
  --trailer "dwp-implementation-version: ${next_implementation_version}" \
  --trailer "dwp-implementer-session-id: ${implementer_session_id}" \
  --prompt "$output_body"
