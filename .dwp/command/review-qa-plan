#!/bin/bash

set -euo pipefail

fail_with_error() {
  local cause="$1"

  trap - ERR
  set +e

  aynig set-state \
    --dwp-state error \
    --subject "review-qa-plan: error" \
    --keep-trailers \
    --prompt "Command failed while reviewing the QA plan.

Cause:
$cause"

  exit 1
}

on_error() {
  local exit_code=$?
  local line_number="$1"

  fail_with_error "${BASH_COMMAND} (line ${line_number}, exit ${exit_code})"
}

trap 'on_error "$LINENO"' ERR

trim() {
  printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

body="$(trim "${AYNIG_BODY:-}")"
ticket_input="$(trim "${AYNIG_TRAILER_DWP_TICKET:-}")"
current_plan_version="$(trim "${AYNIG_TRAILER_DWP_PLAN_VERSION:-}")"
planner_session_id="$(trim "${AYNIG_TRAILER_DWP_PLANNER_SESSION_ID:-}")"
current_implementation_version="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTATION_VERSION:-}")"
implementer_session_id="$(trim "${AYNIG_TRAILER_DWP_IMPLEMENTER_SESSION_ID:-}")"
current_qa_plan_version="$(trim "${AYNIG_TRAILER_DWP_QA_PLAN_VERSION:-}")"
qa_planner_session_id="$(trim "${AYNIG_TRAILER_DWP_QA_PLANNER_SESSION_ID:-}")"

if [ -z "$ticket_input" ]; then
  fail_with_error "Missing dwp-ticket trailer"
fi

for numeric_name in current_plan_version current_implementation_version current_qa_plan_version; do
  value="${!numeric_name}"
  if [ -z "$value" ] || ! [[ "$value" =~ ^[0-9]+$ ]]; then
    fail_with_error "Invalid ${numeric_name} trailer value: ${value:-<empty>}"
  fi
done

if [ -z "$planner_session_id" ]; then
  fail_with_error "Missing dwp-planner-session-id trailer"
fi

if [ -z "$implementer_session_id" ]; then
  fail_with_error "Missing dwp-implementer-session-id trailer"
fi

if [ -z "$qa_planner_session_id" ]; then
  fail_with_error "Missing dwp-qa-planner-session-id trailer"
fi

if [ -z "$body" ]; then
  fail_with_error "Missing latest QA planner notes for reviewer in commit body"
fi

repo_root="$(git rev-parse --show-toplevel)"

case "$ticket_input" in
  /*) ticket_path="$ticket_input" ;;
  *) ticket_path="$repo_root/$ticket_input" ;;
esac

if [ ! -f "$ticket_path" ]; then
  fail_with_error "Ticket not found: $ticket_path"
fi

ticket_file="$(basename "$ticket_path")"
ticket_name="${ticket_file%.md}"
relative_ticket_path="${ticket_path#$repo_root/}"
logs_dir="$repo_root/.dwp/logs"
commit_hash="$(trim "${AYNIG_COMMIT_HASH:-}")"

if [ -z "$commit_hash" ]; then
  fail_with_error "Missing AYNIG_COMMIT_HASH"
fi

output_path="$logs_dir/dwp-output-${commit_hash}.md"
relative_output_path="${output_path#$repo_root/}"
run_title="${commit_hash}-review-qa-plan"

mkdir -p "$logs_dir"
: > "$output_path"

prompt=$(cat <<EOF
You are reviewing the current QA plan for one ticket in the woqso.com product repo.

Your job:
1. Review the ticket as it exists now, including its current QA Plan section.
2. Use the latest QA planner notes as review context.
3. Decide whether the QA plan should be approved, revised again, sent back to implementation, or escalated to a human.
4. Write a short handoff for the next actor in the output file.

Repository context:
- This repository is for woqso.com, a GUI that visualizes the state of repositories that use DWP/git.
- This is not the repository for the DWP protocol or AYNIG implementation itself.
- Treat SPEC.md as the primary product source of truth, then IMPLEMENTATION_PLAN.md, then the ticket.
- Keep these layers clearly separated in your reasoning and writing:
  - DWP/GC protocol facts
  - Git inspection facts
  - UI diagnostics and product heuristics

Decision rule:
- Choose execute-qa when the current QA plan is good enough to execute.
- Choose iterate-qa-plan when the QA plan can be improved by another planning pass.
- Choose iterate-implementation when the QA review reveals substantive implementation gaps that should be fixed before QA execution.
- Choose call-human only when progress is genuinely blocked on human clarification or a product decision that cannot be inferred from the repo context.
- When dwp-qa-plan-version is 3 or higher, tolerate minor issues and request another QA plan iteration only for substantive problems.

Required output file contract:
- Write the review to $relative_output_path.
- The first line of the file must be exactly one of:
  - Decision: execute-qa
  - Decision: iterate-qa-plan
  - Decision: iterate-implementation
  - Decision: call-human
- After the decision line, write the message for the next actor.
- Do not include system logs, raw tool output, or irrelevant analysis.

What to write in the output file:
- If the decision is execute-qa, explain why the QA plan is ready to run and mention important caveats.
- If the decision is iterate-qa-plan, explain what must change in the QA plan before execution.
- If the decision is iterate-implementation, explain what implementation gaps block meaningful QA and what implementation changes are needed.
- If the decision is call-human, explain what human input is required and why.

Files:
- Target ticket: $relative_ticket_path
- Output file: $relative_output_path

QA Planner Notes:
$body
EOF
)

opencode run \
  -m openai/gpt-5.4 \
  --dir "$repo_root" \
  --title "$run_title" \
  -f "$repo_root/SPEC.md" \
  -f "$repo_root/IMPLEMENTATION_PLAN.md" \
  -f "$ticket_path" \
  -f "$output_path" \
  "$prompt"

output_body="$(<"$output_path")"

if [ -z "$output_body" ]; then
  fail_with_error "Output file was empty: $relative_output_path"
fi

IFS= read -r decision_line < "$output_path"
decision_line="$(trim "$decision_line")"

case "$decision_line" in
  "Decision: execute-qa")
    next_state="execute-qa"
    next_subject="review-qa-plan: approve ${ticket_name} qa plan"
    ;;
  "Decision: iterate-qa-plan")
    next_state="iterate-qa-plan"
    next_subject="review-qa-plan: request ${ticket_name} qa plan changes"
    ;;
  "Decision: iterate-implementation")
    next_state="iterate-implementation"
    next_subject="review-qa-plan: request ${ticket_name} implementation changes"
    ;;
  "Decision: call-human")
    next_state="call-human"
    next_subject="review-qa-plan: needs human input for ${ticket_name}"
    ;;
  *)
    fail_with_error "Invalid review decision in $relative_output_path: $decision_line"
    ;;
esac

aynig set-state \
  --dwp-state "$next_state" \
  --subject "$next_subject" \
  --trailer "dwp-ticket: ${relative_ticket_path}" \
  --trailer "dwp-plan-version: ${current_plan_version}" \
  --trailer "dwp-planner-session-id: ${planner_session_id}" \
  --trailer "dwp-implementation-version: ${current_implementation_version}" \
  --trailer "dwp-implementer-session-id: ${implementer_session_id}" \
  --trailer "dwp-qa-plan-version: ${current_qa_plan_version}" \
  --trailer "dwp-qa-planner-session-id: ${qa_planner_session_id}" \
  --prompt "$output_body"
